{
  "version": 2,
  "env": {
    "PYTHONPATH": "/var/task"
  },
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "methods": ["GET", "HEAD"],
      "dest": "/static/$1",
      "headers": {
        "cache-control": "public, s-maxage=31536000, immutable"
      }
    },
    {
      "src": "/public/(.*)",
      "methods": ["GET", "HEAD"],
      "dest": "/public/$1",
      "headers": {
        "cache-control": "public, s-maxage=31536000, immutable"
      }
    },
    {
      "src": "/favicon.ico",
      "dest": "/static/icons/app-icon-192.png"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
