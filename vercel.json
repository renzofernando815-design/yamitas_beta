{
  "version": 2,
  "functions": {
    "api/index.py": {
      "runtime": "python3.11"
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/static/icons/app-icon-192.png"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
